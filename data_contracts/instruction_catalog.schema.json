{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "instruction_catalog",
  "type": "object",
  "required": [
    "trace_id",
    "stage_name",
    "stage_run_id",
    "instruction_name",
    "aliases",
    "opcode_raw",
    "opcode_radix",
    "opcode_value",
    "execution_unit",
    "instruction_kind",
    "confidence_score",
    "source_refs"
  ],
  "properties": {
    "trace_id": { "type": "string" },
    "stage_name": { "type": "string" },
    "stage_run_id": { "type": "string" },
    "instruction_name": { "type": "string" },
    "variation": {
      "type": ["string", "null"],
      "description": "동일 instruction_name 내 레이아웃/니모닉 구분자(예: CW, GW). 단일 형태면 null."
    },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "opcode_raw": {
      "type": "string",
      "description": "문서에 표기된 OPCODE 문자열 그대로(예: 0x1A, 0x1a, 26, 0X1A). 파싱 전 원문 보존."
    },
    "opcode_radix": {
      "type": "string",
      "enum": ["hex", "dec", "unknown"],
      "description": "문서 표기 진법. 0x 접두·16진 문맥이면 hex, 10진만 쓰면 dec, 불명확하면 unknown."
    },
    "opcode_value": {
      "type": ["integer", "null"],
      "description": "정규화된 숫자 값(비교·유일성용). 파싱 불가 시 null."
    },
    "execution_unit": {
      "type": "string",
      "description": "명령이 실행되는 하드웨어 블록(execution unit) 이름. 문서 표기 그대로 또는 정규화 전 단계."
    },
    "execution_unit_id": {
      "type": ["string", "null"],
      "description": "온톨로지/내부용 정규화 ID(선택). ExecutionUnit 노드와 연결."
    },
    "instruction_kind": {
      "type": "string",
      "enum": ["macro", "micro", "unknown"],
      "description": "macro=복합 명령, micro=유닛(단일) 명령, unknown=문서만으로 불명확"
    },
    "instruction_kind_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "instruction_kind 판정 신뢰도(선택)."
    },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "source_refs": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true
}
